APP_NAME=DNS Hub
APP_ENV=development
PORT=8080
APP_MASTER_KEY=MDEyMzQ1Njc4OWFiY2RlZjAxMjM0NTY3ODlhYmNkZWY=
JWT_SECRET=your-production-jwt-secret-here
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_HOURS=168
FRONTEND_URL=http://localhost:5173
BACKEND_PUBLIC_URL=http://localhost:8080
UPLOAD_DIR=uploads
REMINDER_WEBHOOK_URL=
DEV_LOGIN_ENABLED=false
# DNS propagation check resolvers (comma-separated). Defaults to 1.1.1.1,8.8.8.8,114.114.114.114,223.5.5.5,208.67.222.222
# PROPAGATION_RESOLVERS=1.1.1.1:53,8.8.8.8:53

# File attachment storage: "local" (default) or "s3"
STORAGE_TYPE=local
# S3-compatible object storage (used when STORAGE_TYPE=s3)
# S3_ENDPOINT=http://localhost:9000
# S3_REGION=us-east-1
# S3_BUCKET=dns-hub-attachments
# S3_KEY_PREFIX=dns-hub/
# S3_BASE_URL=https://cdn.example.com
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=

POSTGRES_DB=dns_hub
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=dns_hub
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_SSLMODE=disable

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URL=http://localhost:8080/api/v1/auth/oauth/github/callback
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
GITLAB_REDIRECT_URL=http://localhost:8080/api/v1/auth/oauth/gitlab/callback
